#!/usr/bin/env python3

import os
import subprocess
import shutil
from pathlib import Path
import typer
from rich.console import Console
from rich.panel import Panel

CONTEXT_SETTINGS = {"help_option_names": ["-h", "--help"]}

app = typer.Typer(help="¾▒äà ASIX - Asus NixOS CLI", context_settings=CONTEXT_SETTINGS, no_args_is_help=True)
theme_app = typer.Typer(help="¾░©ë Theme Management", context_settings=CONTEXT_SETTINGS, no_args_is_help=True)
system_app = typer.Typer(help="¾░Æô System Operations", context_settings=CONTEXT_SETTINGS, no_args_is_help=True)

app.add_typer(theme_app, name="theme")
app.add_typer(system_app, name="system")

console = Console()

STATE_DIR = Path.home() / ".local" / "state" / "theme"

def ensure_dir(path: Path):
    path.mkdir(parents=True, exist_ok=True)

@theme_app.command("wall")
def theme_wall(image_path: str = typer.Argument(..., help="Path to the image file")):
    """
    ¾░©ë Set the wallpaper and lockscreen image
    """
    img = Path(image_path).expanduser().resolve()
    if not img.exists():
        console.print(f"[red]¾░àÜ Error: File '{img}' not found.[/red]")
        raise typer.Exit(1)
        
    ensure_dir(STATE_DIR)
    
    console.print(f"[cyan]´ä© Copying image to state...[/cyan]")
    shutil.copy(img, STATE_DIR / "wall.png")
    shutil.copy(img, STATE_DIR / "lock.png")
    
    console.print(f"[cyan]´ä© Reloading Hyprpaper...[/cyan]")
    try:
        subprocess.run(["systemctl", "--user", "restart", "hyprpaper"], check=True, capture_output=True)
        console.print(Panel.fit(f"[green]¾░ä¼ Theme successfully updated to:[/green]\n[bold]{img}[/bold]", border_style="green"))
    except subprocess.CalledProcessError as e:
        console.print(f"[red]¾░àÜ Error restarting hyprpaper: {e}[/red]")
        raise typer.Exit(1)

@theme_app.command("init")
def theme_init():
    """
    ¾░ÆŞ Initialize the theme if the state is empty or corrupt.
    """
    console.print("[yellow]¾░ÆŞ Initializing theme defaults via Home Manager...[/yellow]")
    console.print("[cyan]´ä© Running system switch to trigger activation scripts...[/cyan]")
    system_switch()

@system_app.command("switch")
def system_switch():
    """
    ¾░Æô Rebuild and make the new NixOS system configuration persistent (creates a boot generation)
    """
    dotfiles = Path.home() / ".dotfiles"
    console.print(f"[cyan]´ä© Rebuilding and switching NixOS from {dotfiles}...[/cyan]")
    try:
        subprocess.run(["sudo", "nixos-rebuild", "switch", "--flake", str(dotfiles)], check=True)
        console.print("[green]¾░ä¼ System switch complete![/green]")
    except subprocess.CalledProcessError:
        console.print("[red]¾░àÜ System switch failed![/red]")
        raise typer.Exit(1)

@system_app.command("test")
def system_test():
    """
    ¾░Æô Rebuild and test the new NixOS configuration (does NOT create a boot generation)
    """
    dotfiles = Path.home() / ".dotfiles"
    console.print(f"[yellow]´ä© Testing NixOS configuration from {dotfiles}...[/yellow]")
    try:
        subprocess.run(["sudo", "nixos-rebuild", "test", "--flake", str(dotfiles)], check=True)
        console.print("[green]¾░ä¼ System test complete! Changes applied but not saved to boot menu.[/green]")
    except subprocess.CalledProcessError:
        console.print("[red]¾░àÜ System test failed![/red]")
        raise typer.Exit(1)

if __name__ == "__main__":
    app()
